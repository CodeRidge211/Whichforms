{
  "$schema": "https://railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run postinstall"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "releaseCommand": "npx prisma migrate deploy"
  },
  "healthcheck": {
    "path": "/health",
    "port": 3000
  }
}
